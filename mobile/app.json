{
  "expo": {
    "name": "Tricity Verified",
    "slug": "tricity-verified",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Tricity Verified to access your camera for attendance photos.",
          "microphonePermission": "Allow Tricity Verified to access your microphone."
        }
      ],
      "expo-media-library",
      "expo-notifications",
      "expo-system-ui"
    ],
    "android": {
      "package": "com.tricityverified.app",
      "usesCleartextTraffic": true,
      "jsEngine": "jsc"
    },
    "extra": {
      "eas": {
      }
    }
  }
}
